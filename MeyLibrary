            titleLabel.BackgroundTransparency = 1
            titleLabel.Text = title
            titleLabel.TextColor3 = Mey.Theme.Colors.RoseDeep
            titleLabel.TextSize = 20
            titleLabel.FontFace = Mey.Theme.Fonts.Title
            titleLabel.TextXAlignment = Enum.TextXAlignment.Left
            titleLabel.Parent = modal

            local contentLabel = Instance.new("TextLabel")
            contentLabel.Size = UDim2.new(1, -20, 0, 60)
            contentLabel.Position = UDim2.new(0, 10, 0, 55)
            contentLabel.BackgroundTransparency = 1
            contentLabel.Text = content
            contentLabel.TextColor3 = Mey.Theme.Colors.TextDark
            contentLabel.TextSize = 14
            contentLabel.FontFace = Mey.Theme.Fonts.Body
            contentLabel.TextWrapped = true
            contentLabel.TextXAlignment = Enum.TextXAlignment.Left
            contentLabel.TextYAlignment = Enum.TextYAlignment.Top
            contentLabel.Parent = modal

            local btnFrame = Instance.new("Frame")
            btnFrame.Size = UDim2.new(1, -20, 0, 40)
            btnFrame.Position = UDim2.new(0, 10, 1, -50)
            btnFrame.BackgroundTransparency = 1
            btnFrame.Parent = modal

            local btnLayout = Instance.new("UIListLayout")
            btnLayout.Padding = UDim.new(0, 8)
            btnLayout.FillDirection = Enum.FillDirection.Horizontal
            btnLayout.HorizontalAlignment = Enum.HorizontalAlignment.Right
            btnLayout.Parent = btnFrame

            local function close()
                overlay:Destroy()
                if cfg.OnClose then cfg.OnClose() end
            end

            for _, btn in ipairs(buttons) do
                local b = Instance.new("TextButton")
                b.Size = UDim2.new(0, 80, 0, 34)
                b.BackgroundColor3 = btn.Primary and Mey.Theme.Colors.Rose or Mey.Theme.Colors.PanelGlass
                b.BackgroundTransparency = btn.Primary and 0 or 0.2
                b.Text = btn.Text or "OK"
                b.TextColor3 = btn.Primary and Color3.fromRGB(255, 255, 255) or Mey.Theme.Colors.TextDark
                b.TextSize = 14
                b.FontFace = Mey.Theme.Fonts.BodyBold
                b.AutoButtonColor = false
                b.Parent = btnFrame
                NewCorner(b, UDim.new(0, 8))
                if btn.Primary then
                    local stroke = Instance.new("UIStroke")
                    stroke.Color = Mey.Theme.Colors.Gold
                    stroke.Thickness = 1
                    stroke.Parent = b
                end
                b.MouseButton1Click:Connect(function()
                    close()
                    if btn.Callback then btn.Callback(btn.Value or btn.Text) end
                end)
            end

            overlay.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    if not modal:IsAncestorOf(input.Target) then
                        if cfg.CloseOnClickOutside ~= false then
                            close()
                        end
                    end
                end
            end)

            return {
                Close = close,
                SetContent = function(txt)
                    contentLabel.Text = txt
                end,
                SetTitle = function(txt)
                    titleLabel.Text = txt
                end
            }
        end

        function page:CreateTabGroup(tabs)
            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, 0, 0, 40 + #tabs * 30 + 10)
            frame.BackgroundTransparency = 1
            frame.Parent = tab.Page

            local header = Instance.new("Frame")
            header.Size = UDim2.new(1, 0, 0, 40)
            header.BackgroundTransparency = 1
            header.Parent = frame

            local headerLayout = Instance.new("UIListLayout")
            headerLayout.Padding = UDim.new(0, 4)
            headerLayout.FillDirection = Enum.FillDirection.Horizontal
            headerLayout.Parent = header

            local contentContainer = Instance.new("Frame")
            contentContainer.Size = UDim2.new(1, 0, 0, #tabs * 30 + 10)
            contentContainer.Position = UDim2.new(0, 0, 0, 40)
            contentContainer.BackgroundTransparency = 1
            contentContainer.Parent = frame

            local selectedIndex = 1
            local tabButtons = {}

            for i, tabData in ipairs(tabs) do
                local btn = Instance.new("TextButton")
                btn.Size = UDim2.new(0, 100, 0, 34)
                btn.BackgroundColor3 = i == 1 and Mey.Theme.Colors.Rose or Mey.Theme.Colors.PanelGlass
                btn.BackgroundTransparency = i == 1 and 0.1 or 0.5
                btn.Text = tabData.Title or "Tab " .. i
                btn.TextColor3 = Mey.Theme.Colors.TextDark
                btn.TextSize = 14
                btn.FontFace = Mey.Theme.Fonts.Body
                btn.AutoButtonColor = false
                btn.Parent = header
                NewCorner(btn, UDim.new(0, 8))

                local content = Instance.new("Frame")
                content.Size = UDim2.new(1, 0, 1, 0)
                content.BackgroundTransparency = 1
                content.Visible = i == 1
                content.Parent = contentContainer

                local contentLayout = Instance.new("UIListLayout")
                contentLayout.Padding = UDim.new(0, 6)
                contentLayout.Parent = content

                btn.MouseButton1Click:Connect(function()
                    for j, b in ipairs(tabButtons) do
                        b.Button.BackgroundTransparency = j == i and 0.1 or 0.5
                        b.Content.Visible = (j == i)
                    end
                    selectedIndex = i
                    if tabData.OnSelect then tabData.OnSelect(i) end
                end)

                table.insert(tabButtons, {
                    Button = btn,
                    Content = content,
                    Add = function(child)
                        child.Parent = content
                    end
                })

                if tabData.Content then
                    for _, item in ipairs(tabData.Content) do
                        item.Parent = content
                    end
                end
            end

            return {
                Select = function(index)
                    if index >= 1 and index <= #tabButtons then
                        for j, tb in ipairs(tabButtons) do
                            tb.Button.BackgroundTransparency = j == index and 0.1 or 0.5
                            tb.Content.Visible = (j == index)
                        end
                        selectedIndex = index
                        if tabs[index] and tabs[index].OnSelect then
                            tabs[index].OnSelect(index)
                        end
                    end
                end,
                GetSelected = function()
                    return selectedIndex
                end,
                GetTab = function(index)
                    return tabButtons[index]
                end
            }
        end

        function page:CreateListBox(cfg)
            cfg = cfg or {}
            local items = cfg.Items or {}
            local selected = cfg.Default or 1

            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, 0, 0, cfg.Height or 200)
            frame.BackgroundColor3 = Mey.Theme.Colors.PanelGlass
            frame.BackgroundTransparency = 0.05
            frame.ClipsDescendants = true
            frame.Parent = tab.Page
            NewCorner(frame, UDim.new(0, 12))

            local stroke = Instance.new("UIStroke")
            stroke.Color = Mey.Theme.Colors.InputBorder
            stroke.Thickness = 1
            stroke.Transparency = 0.5
            stroke.Parent = frame

            local scroll = Instance.new("ScrollingFrame")
            scroll.Size = UDim2.new(1, -10, 1, -10)
            scroll.Position = UDim2.new(0, 5, 0, 5)
            scroll.BackgroundTransparency = 1
            scroll.ScrollBarThickness = 4
            scroll.ScrollBarImageColor3 = Mey.Theme.Colors.Rose
            scroll.Parent = frame

            local layout = Instance.new("UIListLayout")
            layout.Padding = UDim.new(0, 2)
            layout.Parent = scroll

            local buttons = {}

            local function UpdateSelection()
                for i, btn in ipairs(buttons) do
                    btn.BackgroundTransparency = (i == selected) and 0.1 or 0.8
                    btn.TextColor3 = (i == selected) and Mey.Theme.Colors.RoseDeep or Mey.Theme.Colors.TextDark
                end
                if cfg.Callback then cfg.Callback(selected, items[selected]) end
            end

            for i, item in ipairs(items) do
                local btn = Instance.new("TextButton")
                btn.Size = UDim2.new(1, 0, 0, 30)
                btn.BackgroundColor3 = Mey.Theme.Colors.PanelGlass
                btn.BackgroundTransparency = (i == selected) and 0.1 or 0.8
                btn.Text = item
                btn.TextColor3 = (i == selected) and Mey.Theme.Colors.RoseDeep or Mey.Theme.Colors.TextDark
                btn.TextSize = 14
                btn.FontFace = Mey.Theme.Fonts.Body
                btn.TextXAlignment = Enum.TextXAlignment.Left
                btn.AutoButtonColor = false
                btn.Parent = scroll
                NewCorner(btn, UDim.new(0, 6))
                btn.MouseButton1Click:Connect(function()
                    selected = i
                    UpdateSelection()
                end)
                table.insert(buttons, btn)
            end

            UpdateSelection()

            return {
                Set = function(index)
                    if index >= 1 and index <= #items then
                        selected = index
                        UpdateSelection()
                    end
                end,
                Get = function()
                    return selected
                end,
                GetValue = function()
                    return items[selected]
                end,
                Refresh = function(newItems)
                    items = newItems
                    for _, child in ipairs(scroll:GetChildren()) do
                        if child:IsA("TextButton") then
                            child:Destroy()
                        end
                    end
                    buttons = {}
                    for i, item in ipairs(items) do
                        local btn = Instance.new("TextButton")
                        btn.Size = UDim2.new(1, 0, 0, 30)
                        btn.BackgroundColor3 = Mey.Theme.Colors.PanelGlass
                        btn.BackgroundTransparency = (i == selected) and 0.1 or 0.8
                        btn.Text = item
                        btn.TextColor3 = (i == selected) and Mey.Theme.Colors.RoseDeep or Mey.Theme.Colors.TextDark
                        btn.TextSize = 14
                        btn.FontFace = Mey.Theme.Fonts.Body
                        btn.TextXAlignment = Enum.TextXAlignment.Left
                        btn.AutoButtonColor = false
                        btn.Parent = scroll
                        NewCorner(btn, UDim.new(0, 6))
                        btn.MouseButton1Click:Connect(function()
                            selected = i
                            UpdateSelection()
                        end)
                        table.insert(buttons, btn)
                    end
                    UpdateSelection()
                end
            }
        end

        function page:CreateSpinner(cfg)
            cfg = cfg or {}
            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, 0, 0, cfg.Height or 60)
            frame.BackgroundTransparency = 1
            frame.Parent = tab.Page

            local spinner = Instance.new("Frame")
            spinner.Size = UDim2.new(0, 40, 0, 40)
            spinner.Position = UDim2.new(0.5, -20, 0.5, -20)
            spinner.BackgroundColor3 = Mey.Theme.Colors.Rose
            spinner.BackgroundTransparency = 0.8
            spinner.Parent = frame
            NewCorner(spinner, UDim.new(1, 0))

            local stroke = Instance.new("UIStroke")
            stroke.Color = Mey.Theme.Colors.Gold
            stroke.Thickness = 3
            stroke.Parent = spinner

            local text = Instance.new("TextLabel")
            text.Size = UDim2.new(1, 0, 0, 20)
            text.Position = UDim2.new(0, 0, 1, 5)
            text.BackgroundTransparency = 1
            text.Text = cfg.Text or "Loading..."
            text.TextColor3 = Mey.Theme.Colors.TextDark
            text.TextSize = 14
            text.FontFace = Mey.Theme.Fonts.Body
            text.TextXAlignment = Enum.TextXAlignment.Center
            text.TextTransparency = 0.5
            text.Parent = frame

            local running = true
            local connection

            local function animate()
                local angle = 0
                connection = RunService.Heartbeat:Connect(function(dt)
                    if not running then
                        connection:Disconnect()
                        return
                    end
                    angle = angle + dt * 3
                    spinner.Rotation = angle % 360
                end)
            end

            animate()

            return {
                Start = function()
                    running = true
                    animate()
                end,
                Stop = function()
                    running = false
                    if connection then connection:Disconnect() end
                end,
                SetText = function(txt)
                    text.Text = txt
                end
            }
        end

        function page:CreateTooltip(cfg)
            cfg = cfg or {}
            local target = cfg.Target
            local text = cfg.Text or "Tooltip"

            if not target then return end

            local tip = Instance.new("TextLabel")
            tip.Size = UDim2.new(0, cfg.Width or 150, 0, 20)
            tip.BackgroundColor3 = Mey.Theme.Colors.TooltipBg
            tip.BackgroundTransparency = 0.8
            tip.Text = text
            tip.TextColor3 = Mey.Theme.Colors.TooltipText
            tip.TextSize = 12
            tip.FontFace = Mey.Theme.Fonts.Body
            tip.Visible = false
            tip.Parent = target
            NewCorner(tip, UDim.new(0, 6))

            if cfg.Position == "Top" then
                tip.Position = UDim2.new(0.5, -cfg.Width/2, 0, -25)
            elseif cfg.Position == "Bottom" then
                tip.Position = UDim2.new(0.5, -cfg.Width/2, 1, 5)
            elseif cfg.Position == "Left" then
                tip.Position = UDim2.new(0, -cfg.Width-10, 0.5, -10)
            elseif cfg.Position == "Right" then
                tip.Position = UDim2.new(1, 10, 0.5, -10)
            else
                tip.Position = UDim2.new(0.5, -cfg.Width/2, 0, -25)
            end

            target.MouseEnter:Connect(function()
                if cfg.Condition == nil or cfg.Condition() then
                    tip.Visible = true
                end
            end)
            target.MouseLeave:Connect(function()
                tip.Visible = false
            end)

            return {
                Show = function()
                    tip.Visible = true
                end,
                Hide = function()
                    tip.Visible = false
                end,
                SetText = function(txt)
                    tip.Text = txt
                end
            }
        end

        function page:CreateHyperlink(cfg)
            cfg = cfg or {}
            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, 0, 0, 30)
            frame.BackgroundTransparency = 1
            frame.Parent = tab.Page

            local label = Instance.new("TextButton")
            label.Size = UDim2.new(1, 0, 1, 0)
            label.BackgroundTransparency = 1
            label.Text = cfg.Text or "Link"
            label.TextColor3 = cfg.Color or Color3.fromRGB(80, 150, 255)
            label.TextSize = cfg.Size or 14
            label.FontFace = Mey.Theme.Fonts.Body
            label.TextXAlignment = cfg.Alignment or Enum.TextXAlignment.Left
            label.AutoButtonColor = false
            label.Parent = frame

            local underline = Instance.new("Frame")
            underline.Size = UDim2.new(1, 0, 0, 1)
            underline.Position = UDim2.new(0, 0, 1, -1)
            underline.BackgroundColor3 = cfg.Color or Color3.fromRGB(80, 150, 255)
            underline.BackgroundTransparency = 0.5
            underline.Parent = label

            label.MouseEnter:Connect(function()
                underline.BackgroundTransparency = 0
                label.TextColor3 = (cfg.Color or Color3.fromRGB(80, 150, 255)):Lerp(Color3.fromRGB(255, 255, 255), 0.3)
            end)
            label.MouseLeave:Connect(function()
                underline.BackgroundTransparency = 0.5
                label.TextColor3 = cfg.Color or Color3.fromRGB(80, 150, 255)
            end)
            label.MouseButton1Click:Connect(function()
                if cfg.Callback then cfg.Callback() end
                if cfg.Url then
                    setclipboard(cfg.Url)
                    Mey:NotifyToast({ Text = "Copied URL: " .. cfg.Url, Duration = 2 })
                end
            end)

            return label
        end

        function page:SelectTab(index)
            if index >= 1 and index <= #window.Tabs then
                local tab = window.Tabs[index]
                if tab and tab.Button then
                    tab.Button:Click()
                end
            end
        end

        return page
    end

    return window
end

return Mey
