			NewCorner(fill, UDim.new(1, 0))

			local fillGrad = Instance.new("UIGradient")
			fillGrad.Color = ColorSequence.new(Mey.Theme.Colors.SliderFillA, Mey.Theme.Colors.SliderFillB)
			fillGrad.Parent = fill

			local handle = Instance.new("Frame")
			handle.AnchorPoint = Vector2.new(0.5, 0.5)
			handle.Size = UDim2.new(0, 24, 0, 24)
			handle.BackgroundColor3 = Mey.Theme.Colors.PanelGlass
			handle.ZIndex = 2
			handle.Parent = track
			NewCorner(handle, UDim.new(1, 0))

			local handleStroke = Instance.new("UIStroke")
			handleStroke.Color = Mey.Theme.Colors.RoseDeep
			handleStroke.Thickness = 2
			handleStroke.Parent = handle

			local min, max = cfg.Min or 0, cfg.Max or 100
			local value = cfg.Default or min

			local function Update(frac)
				frac = math.clamp(frac, 0, 1)
				value = math.floor(min + (max - min) * frac)
				Tween(fill, { Size = UDim2.new(frac, 0, 1, 0) }, 0.05)
				handle.Position = UDim2.new(frac, 0, 0.5, 0)
				valueLabel.Text = tostring(value)
				if cfg.Callback then
					cfg.Callback(value)
				end
			end

			local dragging = false
			local dragConnection = nil
			local endConnection = nil

			local function startDrag(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = true
					Update((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X)
					endConnection = input.Changed:Connect(function()
						if input.UserInputState == Enum.UserInputState.End then
							dragging = false
							if endConnection then endConnection:Disconnect() end
							if dragConnection then dragConnection:Disconnect() end
						end
					end)
					if not dragConnection then
						dragConnection = UserInputService.InputChanged:Connect(function(input2)
							if dragging and (input2.UserInputType == Enum.UserInputType.MouseMovement or input2.UserInputType == Enum.UserInputType.Touch) then
								Update((input2.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X)
							end
						end)
						table.insert(window.Connections, dragConnection)
					end
				end
			end

			track.InputBegan:Connect(startDrag)

			local initFrac = (value - min) / (max - min)
			fill.Size = UDim2.new(initFrac, 0, 1, 0)
			handle.Position = UDim2.new(initFrac, 0, 0.5, 0)

			return {
				Set = function(v)
					value = math.clamp(v, min, max)
					local frac = (value - min) / (max - min)
					Tween(fill, { Size = UDim2.new(frac, 0, 1, 0) }, 0.1)
					handle.Position = UDim2.new(frac, 0, 0.5, 0)
					valueLabel.Text = tostring(value)
				end,
				Get = function()
					return value
				end,
			}
		end

