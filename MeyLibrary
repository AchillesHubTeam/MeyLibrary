function Mey:NotifyConfirm(config)
    config.Buttons = {
        { Text = "Confirm", Value = true },
        { Text = "Cancel", Value = false }
    }
    return Mey:Notify(config)
end

function Mey:NotifyInput(config)
    local result = nil
    local frame = Mey:Notify({
        Title = config.Title or "Input",
        Content = "",
        Duration = 999,
        Buttons = {
            { Text = "OK", Value = "ok" },
            { Text = "Cancel", Value = "cancel" }
        },
        OnAction = function(v)
            if v == "ok" then
                if config.Callback then config.Callback(result) end
            end
        end
    })

    local contentLabel = frame:FindFirstChildOfClass("TextLabel")
    if contentLabel then
        contentLabel.Text = ""
    end

    local inputBox = Instance.new("TextBox")
    inputBox.Size = UDim2.new(1, -20, 0, 30)
    inputBox.Position = UDim2.new(0, 10, 0, 40)
    inputBox.BackgroundColor3 = Mey.Theme.Colors.PanelGlass
    inputBox.BackgroundTransparency = 0.15
    inputBox.Text = config.Default or ""
    inputBox.PlaceholderText = config.Placeholder or "Enter value..."
    inputBox.TextColor3 = Mey.Theme.Colors.TextDark
    inputBox.FontFace = Mey.Theme.Fonts.Body
    inputBox.TextSize = 14
    inputBox.ClearTextOnFocus = false
    inputBox.Parent = frame
    NewCorner(inputBox, UDim.new(0, 8))

    inputBox:GetPropertyChangedSignal("Text"):Connect(function()
        result = inputBox.Text
    end)

    return {
        Get = function() return result end,
        Set = function(v) inputBox.Text = v end
    }
end

