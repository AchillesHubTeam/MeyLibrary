            label.Size = UDim2.new(1, -60, 1, 0)
            label.Text = cfg.Text or "Badge"
            label.TextColor3 = Mey.Theme.Colors.TextDark
            label.BackgroundTransparency = 1
            label.FontFace = Mey.Theme.Fonts.Body
            label.TextSize = 14
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.Parent = frame

            local badge = Instance.new("Frame")
            badge.Size = UDim2.new(0, 30, 0, 30)
            badge.Position = UDim2.new(1, -30, 0.5, -15)
            badge.BackgroundColor3 = cfg.Color or Mey.Theme.Colors.BadgeBg
            badge.Parent = frame
            NewCorner(badge, UDim.new(1, 0))

            local countLabel = Instance.new("TextLabel")
            countLabel.Size = UDim2.new(1, 0, 1, 0)
            countLabel.BackgroundTransparency = 1
            countLabel.Text = tostring(count)
            countLabel.TextColor3 = Mey.Theme.Colors.BadgeText
            countLabel.TextSize = 14
            countLabel.FontFace = Mey.Theme.Fonts.BodyBold
            countLabel.Parent = badge

            local function Update(v)
                count = v
                local display = count > maxCount and maxCount .. "+" or tostring(count)
                countLabel.Text = display
                if count == 0 then
                    badge.Visible = false
                else
                    badge.Visible = true
                    local width = math.max(30, 20 + #display * 10)
                    badge.Size = UDim2.new(0, width, 0, 30)
                end
                if cfg.Callback then cfg.Callback(count) end
            end

            Update(count)

            return {
                Set = function(v)
                    Update(v)
                end,
                Get = function()
                    return count
                end,
                Increment = function(amount)
                    Update(count + (amount or 1))
                end
            }
        end

