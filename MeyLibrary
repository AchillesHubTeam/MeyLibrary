			bindBtn.TextColor3 = Mey.Theme.Colors.TextDark
			bindBtn.FontFace = Mey.Theme.Fonts.Body
			bindBtn.TextSize = 14
			bindBtn.AutoButtonColor = false
			bindBtn.Parent = frame
			NewCorner(bindBtn, UDim.new(0, 14))

			local stroke = Instance.new("UIStroke")
			stroke.Color = Mey.Theme.Colors.InputBorder
			stroke.Thickness = 1.5
			stroke.Parent = bindBtn

			local isListening = false
			local keyConnection = nil

			bindBtn.MouseButton1Click:Connect(function()
				if isListening then
					isListening = false
					if keyConnection then keyConnection:Disconnect() end
					bindBtn.Text = key == Enum.KeyCode.None and "None" or key.Name
					return
				end
				isListening = true
				bindBtn.Text = "..."
				keyConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
					if gameProcessed then return end
					if input.UserInputType == Enum.UserInputType.Keyboard then
						key = input.KeyCode
						isListening = false
						bindBtn.Text = key.Name
						if keyConnection then keyConnection:Disconnect() end
						if cfg.Callback then cfg.Callback(key) end
					end
				end)
			end)

			return {
				Set = function(k)
					key = k
					bindBtn.Text = key == Enum.KeyCode.None and "None" or key.Name
					if cfg.Callback then cfg.Callback(key) end
				end,
				Get = function()
					return key
				end,
			}
		end

