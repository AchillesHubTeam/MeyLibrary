            label.FontFace = Mey.Theme.Fonts.BodyBold
            label.TextSize = 14
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.Parent = frame

            local buttons = {}
            local function updateButtons()
                for i, opt in ipairs(options) do
                    local btn = buttons[i]
                    if btn then
                        local isSelected = (opt == selected)
                        btn.Check.Visible = isSelected
                        if isSelected then
                            Tween(btn.Box, { BackgroundColor3 = Mey.Theme.Colors.RadioActive })
                        else
                            Tween(btn.Box, { BackgroundColor3 = Mey.Theme.Colors.RadioBg })
                        end
                    end
                end
                if cfg.Callback then
                    cfg.Callback(selected)
                end
            end

            for i, opt in ipairs(options) do
                local row = Instance.new("Frame")
                row.Size = UDim2.new(1, 0, 0, 30)
                row.Position = UDim2.new(0, 0, 0, 30 + (i-1) * 30)
                row.BackgroundTransparency = 1
                row.Parent = frame

                local box = Instance.new("TextButton")
                box.Size = UDim2.new(0, 20, 0, 20)
                box.Position = UDim2.new(0, 0, 0.5, -10)
                box.BackgroundColor3 = Mey.Theme.Colors.RadioBg
                box.Text = ""
                box.AutoButtonColor = false
                box.Parent = row
                NewCorner(box, UDim.new(1, 0))

                local check = Instance.new("Frame")
                check.Size = UDim2.new(0, 10, 0, 10)
                check.Position = UDim2.new(0.5, -5, 0.5, -5)
                check.BackgroundColor3 = Mey.Theme.Colors.RadioActive
                check.BackgroundTransparency = 1
                check.Parent = box
                NewCorner(check, UDim.new(1, 0))

                local optLabel = Instance.new("TextLabel")
                optLabel.Size = UDim2.new(1, -30, 1, 0)
                optLabel.Position = UDim2.new(0, 25, 0, 0)
                optLabel.BackgroundTransparency = 1
                optLabel.Text = opt
                optLabel.TextColor3 = Mey.Theme.Colors.TextDark
                optLabel.FontFace = Mey.Theme.Fonts.Body
                optLabel.TextSize = 14
                optLabel.TextXAlignment = Enum.TextXAlignment.Left
                optLabel.Parent = row

                table.insert(buttons, { Box = box, Check = check, Label = optLabel })

                box.MouseButton1Click:Connect(function()
                    selected = opt
                    updateButtons()
                end)
            end

            updateButtons()

            return {
                Set = function(v)
                    if table.find(options, v) then
                        selected = v
                        updateButtons()
                    end
                end,
                Get = function()
                    return selected
                end,
                GetIndex = function()
                    for i, v in ipairs(options) do
                        if v == selected then return i end
                    end
                    return 1
                end
            }
        end

