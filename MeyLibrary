function Mey:CreateWindow(config)
    config = config or {}
    local title = config.Title or "Cloud Kingdom"
    local size = config.Size or Mey.Settings.DefaultSize
    local scaledSize = scaleUDim2(size)

    local window = {
        Tabs = {},
        CurrentTab = nil,
        Minimized = false,
        Unloaded = false,
        Connections = {},
        _savedPosition = nil,
        _size = scaledSize,
        _isDragging = false,
        _isResizing = false,
    }

    local player = Players.LocalPlayer
    local playerGui = player:WaitForChild("PlayerGui")

    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "Mey_UI"
    screenGui.ResetOnSpawn = false
    screenGui.IgnoreGuiInset = true
    screenGui.Parent = playerGui

    local panel = Instance.new("Frame")
    panel.Name = "Panel"
    panel.Size = scaledSize
    panel.Position = UDim2.new(0.5, -scaledSize.X.Offset / 2, 0.5, -scaledSize.Y.Offset / 2)
    panel.BackgroundColor3 = Mey.Theme.Colors.PanelGlass
    panel.BackgroundTransparency = 0.5
    panel.BorderSizePixel = 0
    panel.ClipsDescendants = false
    panel.Parent = screenGui

    local panelGradient = Instance.new("UIGradient")
    panelGradient.Color = ColorSequence.new(Mey.Theme.Colors.PanelGlass, Mey.Theme.Colors.PanelTint)
    panelGradient.Rotation = 90
    panelGradient.Parent = panel

    local panelStroke = Instance.new("UIStroke")
    panelStroke.Color = Mey.Theme.Colors.Gold
    panelStroke.Thickness = 2
    panelStroke.Parent = panel

    local cloudScale = 1.0
    local panelCorners = {
        {0, 0},
        {scaledSize.X.Offset, 0},
        {0, scaledSize.Y.Offset},
        {scaledSize.X.Offset, scaledSize.Y.Offset},
    }
    for _, c in ipairs(panelCorners) do
        CreateCloudIcon(panel, c[1] - 32, c[2] - 20, cloudScale, Mey.Theme.Colors.CloudWhite, 1)
        CreateCloudIcon(panel, c[1] - 14, c[2] - 8, 0.6 * cloudScale, Mey.Theme.Colors.CloudPinkLight, 0.9)
    end

    local icon = Instance.new("ImageLabel")
    icon.Name = "MinimizeIcon"
    icon.Size = UDim2.new(0, 50, 0, 50)
    icon.Position = UDim2.new(1, -60, 1, -60)
    icon.Image = "rbxassetid://105025328866768"
    icon.BackgroundColor3 = Mey.Theme.Colors.Rose
    icon.BackgroundTransparency = 0
    icon.Visible = false
    icon.Parent = screenGui
    NewCorner(icon, UDim.new(1, 0))
    local iconStroke = Instance.new("UIStroke")
    iconStroke.Color = Mey.Theme.Colors.Gold
    iconStroke.Thickness = 2
    iconStroke.Parent = icon

    function window:Destroy()
        for _, conn in ipairs(window.Connections) do
            conn:Disconnect()
        end
        window.Unloaded = true
        screenGui:Destroy()
    end

    function window:Minimize()
        window.Minimized = true
        window._savedPosition = panel.Position
        panel.Visible = false
        icon.Visible = true
        icon.Position = UDim2.new(1, -60, 1, -60)
    end

    function window:Maximize()
        window.Minimized = false
        icon.Visible = false
        panel.Visible = true
        if window._savedPosition then
            panel.Position = window._savedPosition
        end
    end

    function window:ToggleMinimize()
        if window.Minimized then
            window:Maximize()
        else
            window:Minimize()
        end
    end

    function window:Resize(newSize)
        newSize = UDim2.new(
            math.max(newSize.X.Scale, Mey.Settings.MinSize.X.Scale),
            math.max(newSize.X.Offset, Mey.Settings.MinSize.X.Offset),
            math.max(newSize.Y.Scale, Mey.Settings.MinSize.Y.Scale),
            math.max(newSize.Y.Offset, Mey.Settings.MinSize.Y.Offset)
        )
        newSize = UDim2.new(
            math.min(newSize.X.Scale, Mey.Settings.MaxSize.X.Scale),
            math.min(newSize.X.Offset, Mey.Settings.MaxSize.X.Offset),
            math.min(newSize.Y.Scale, Mey.Settings.MaxSize.Y.Scale),
            math.min(newSize.Y.Offset, Mey.Settings.MaxSize.Y.Offset)
        )
        window._size = newSize
        Tween(panel, { Size = newSize }, 0.3)
    end

    function window:GetSize()
        return panel.Size
    end

    function window:SetTitle(newTitle)
        titleLabel.Text = newTitle
    end

    local dragging, dragInput, dragStart, startPos
    if Mey.Settings.Draggable then
        panel.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                dragStart = input.Position
                startPos = panel.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        dragging = false
                    end
                end)
            end
        end)
        panel.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                dragInput = input
            end
        end)
        table.insert(
            window.Connections,
            UserInputService.InputChanged:Connect(function(input)
                if input == dragInput and dragging then
                    local delta = input.Position - dragStart
                    panel.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
                end
            end)
        )
    end

    local iconDragging, iconDragInput, iconDragStart, iconStartPos
    icon.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            iconDragging = true
            iconDragStart = input.Position
            iconStartPos = icon.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    iconDragging = false
                end
            end)
        end
    end)
    icon.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            iconDragInput = input
        end
    end)
    table.insert(
        window.Connections,
        UserInputService.InputChanged:Connect(function(input)
            if input == iconDragInput and iconDragging then
                local delta = input.Position - iconDragStart
                icon.Position = UDim2.new(iconStartPos.X.Scale, iconStartPos.X.Offset + delta.X, iconStartPos.Y.Scale, iconStartPos.Y.Offset + delta.Y)
            end
        end)
    )

    icon.MouseButton1Click:Connect(function()
        if window.Minimized then
            window:Maximize()
        end
    end)

    if Mey.Settings.Resizable then
        local resizeHandle = Instance.new("Frame")
        resizeHandle.Size = UDim2.new(0, 20, 0, 20)
        resizeHandle.Position = UDim2.new(1, -20, 1, -20)
        resizeHandle.BackgroundColor3 = Mey.Theme.Colors.Gold
        resizeHandle.BackgroundTransparency = 0.5
        resizeHandle.Parent = panel
        NewCorner(resizeHandle, UDim.new(1, 0))
        local resizeStroke = Instance.new("UIStroke")
        resizeStroke.Color = Mey.Theme.Colors.RoseDeep
        resizeStroke.Thickness = 1
        resizeStroke.Parent = resizeHandle

        local resizing = false
        local resizeStart, resizeStartPos, resizeStartSize
        resizeHandle.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                resizing = true
                resizeStart = input.Position
                resizeStartPos = panel.Position
                resizeStartSize = panel.Size
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        resizing = false
                    end
                end)
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local delta = input.Position - resizeStart
                local newWidth = math.max(resizeStartSize.X.Offset + delta.X, Mey.Settings.MinSize.X.Offset)
                local newHeight = math.max(resizeStartSize.Y.Offset + delta.Y, Mey.Settings.MinSize.Y.Offset)
                newWidth = math.min(newWidth, Mey.Settings.MaxSize.X.Offset)
                newHeight = math.min(newHeight, Mey.Settings.MaxSize.Y.Offset)
                panel.Size = UDim2.new(0, newWidth, 0, newHeight)
                window._size = panel.Size
            end
        end)
    end

    local titleBar = Instance.new("Frame")
    titleBar.Name = "TitleBar"
    titleBar.Size = UDim2.new(1, 0, 0, 70)
    titleBar.BackgroundColor3 = Mey.Theme.Colors.PanelGlass
    titleBar.BackgroundTransparency = 0.6
    titleBar.BorderSizePixel = 0
    titleBar.Parent = panel

    local titleLabel = Instance.new("TextLabel")
    titleLabel.Size = UDim2.new(1, -70, 1, 0)
    titleLabel.Position = UDim2.new(0, 10, 0, 0)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = title
    titleLabel.TextColor3 = Mey.Theme.Colors.RoseDeep
    titleLabel.TextSize = 26
    titleLabel.FontFace = Mey.Theme.Fonts.Title
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = titleBar

    local controls = Instance.new("Frame")
    controls.Size = UDim2.new(0, 80, 0, 35)
    controls.Position = UDim2.new(1, -85, 0, 0)
    controls.BackgroundTransparency = 1
    controls.Parent = titleBar

    local function CreateControl(label, x, color, callback, tooltipText)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, 22, 0, 22)
        btn.Position = UDim2.new(0, x, 0.5, -11)
        btn.BackgroundColor3 = color
        btn.Text = label
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.FontFace = Mey.Theme.Fonts.BodyBold
        btn.AutoButtonColor = false
        btn.Parent = controls
        NewCorner(btn, UDim.new(1, 0))

        if tooltipText and Mey.Settings.ShowTooltips then
            local tip = Instance.new("TextLabel")
            tip.Size = UDim2.new(0, 100, 0, 20)
            tip.Position = UDim2.new(0.5, -50, 1, 5)
            tip.BackgroundColor3 = Mey.Theme.Colors.TooltipBg
            tip.BackgroundTransparency = 0.8
            tip.Text = tooltipText
            tip.TextColor3 = Mey.Theme.Colors.TooltipText
            tip.TextSize = 12
            tip.FontFace = Mey.Theme.Fonts.Body
            tip.Visible = false
            tip.Parent = btn
            NewCorner(tip, UDim.new(0, 6))

            btn.MouseEnter:Connect(function() tip.Visible = true end)
            btn.MouseLeave:Connect(function() tip.Visible = false end)
        end

        btn.MouseButton1Click:Connect(callback)
        return btn
    end

    if Mey.Settings.Closable then
        CreateControl("×", 55, Mey.Theme.Colors.Rose, function()
            Tween(panel, { Size = UDim2.new(0, window._size.X.Offset, 0, 0) }, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In).Completed:Connect(function()
                window:Destroy()
            end)
        end, "Close")
    end

    if Mey.Settings.Minimizable then
        CreateControl("−", 25, Mey.Theme.Colors.Gold, function()
            window:ToggleMinimize()
        end, "Minimize")
