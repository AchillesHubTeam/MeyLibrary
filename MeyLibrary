			button.AutoButtonColor = false
			button.Parent = frame
			NewCorner(button, UDim.new(0, 14))

			local stroke = Instance.new("UIStroke")
			stroke.Color = Mey.Theme.Colors.InputBorder
			stroke.Thickness = 1.5
			stroke.Parent = button

			local dropdown = Instance.new("Frame")
			dropdown.Size = UDim2.new(0, 180, 0, 0)
			dropdown.Position = UDim2.new(1, -180, 0, 34)
			dropdown.BackgroundColor3 = Mey.Theme.Colors.DropdownBg
			dropdown.ClipsDescendants = true
			dropdown.Visible = false
			dropdown.Parent = frame
			NewCorner(dropdown, UDim.new(0, 14))

			local dropdownStroke = Instance.new("UIStroke")
			dropdownStroke.Color = Mey.Theme.Colors.InputBorder
			dropdownStroke.Thickness = 1.5
			dropdownStroke.Parent = dropdown

			local list = Instance.new("UIListLayout")
			list.Padding = UDim.new(0, 2)
			list.Parent = dropdown

			local function updateDropdown()
				for _, child in ipairs(dropdown:GetChildren()) do
					if child:IsA("TextButton") then
						child:Destroy()
					end
				end
				local height = 0
				for _, opt in ipairs(options) do
					local optBtn = Instance.new("TextButton")
					optBtn.Size = UDim2.new(1, 0, 0, 30)
					optBtn.BackgroundTransparency = 1
					optBtn.Text = opt
					optBtn.TextColor3 = Mey.Theme.Colors.TextDark
					optBtn.FontFace = Mey.Theme.Fonts.Body
					optBtn.TextSize = 14
					optBtn.AutoButtonColor = false
					optBtn.Parent = dropdown
					optBtn.MouseEnter:Connect(function()
						Tween(optBtn, { BackgroundTransparency = 0.85 }, 0.1)
					end)
					optBtn.MouseLeave:Connect(function()
						Tween(optBtn, { BackgroundTransparency = 1 }, 0.1)
					end)
					optBtn.MouseButton1Click:Connect(function()
						value = opt
						button.Text = value
						if cfg.Callback then cfg.Callback(value) end
						dropdown.Visible = false
						Tween(dropdown, { Size = UDim2.new(0, 180, 0, 0) }, 0.2)
					end)
					height = height + 30
				end
				dropdown.Size = UDim2.new(0, 180, 0, height)
			end

			updateDropdown()

			button.MouseButton1Click:Connect(function()
				if dropdown.Visible then
					dropdown.Visible = false
					Tween(dropdown, { Size = UDim2.new(0, 180, 0, 0) }, 0.2)
				else
					dropdown.Visible = true
					Tween(dropdown, { Size = UDim2.new(0, 180, 0, #options * 30) }, 0.2)
				end
			end)

			return {
				Set = function(v)
					if table.find(options, v) then
						value = v
						button.Text = value
						if cfg.Callback then cfg.Callback(value) end
					end
				end,
				Get = function()
					return value
				end,
				Refresh = function(newOptions)
					options = newOptions
					if not table.find(options, value) then
						value = options[1] or ""
						button.Text = value
					end
					updateDropdown()
				end
			}
		end

